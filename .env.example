# 复制为 .env.local 并填入。

# ── 模型(NPC 大脑)── 三件套,任何 OpenAI 兼容端点都行:
LLM_API_KEY=             # 服务商的 key(必填)
LLM_MODEL=              # 模型名,如 gpt-4o-mini / deepseek-chat / glm-4-flash(必填)
LLM_BASE_URL=           # 接口地址,如 https://api.deepseek.com/v1(选填,留空=OpenAI 官方)

# 可选:
# LLM_MAX_TOKENS=1024   # 思考/推理模型建议调高,如 2048
# LLM_TOOL_MODE=auto    # auto(默认) | tool(强制函数调用) | json(纯推理模型用)

# ── 排行榜/埋点存储 ── 本地可不填(用文件);部署到 serverless 必填:
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx
